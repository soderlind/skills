#!/bin/bash
# Plugin Check (PCP) wrapper for Local by Flywheel sites
#
# Runs the WordPress "Plugin Check" plugin's WP-CLI command
# (`wp plugin check <slug>`) against a Local site.
#
# Auto-detects the site from CWD by matching against sites.json paths and,
# when run from inside wp-content/plugins/<slug>, auto-detects the plugin slug.
# Falls back to --site=<name> / an explicit <slug> argument.
#
# Usage:
#   pcp                             # auto-detect site + plugin from CWD
#   pcp <slug> [check-args...]      # explicit plugin slug
#   pcp --site=<name> <slug> [...]  # explicit site + slug
#   pcp --list                      # show all sites with status
#
# Any additional arguments are forwarded to `wp plugin check`, e.g.:
#   pcp my-plugin --format=csv --categories=plugin_repo
#   pcp my-plugin --ignore-warnings

set -euo pipefail

LOCAL_BASE="$HOME/Library/Application Support/Local"
SITES_JSON="$LOCAL_BASE/sites.json"
STATUSES_JSON="$LOCAL_BASE/site-statuses.json"
ARCH="$(uname -m)"

if [[ "$ARCH" == "arm64" ]]; then
  ARCH_DIR="darwin-arm64"
else
  ARCH_DIR="darwin"
fi

# Locate WP-CLI phar
WP_CLI_BIN=$(command -v wp 2>/dev/null || true)
if [[ -z "$WP_CLI_BIN" ]]; then
  echo "Error: wp (WP-CLI) not found in PATH." >&2
  exit 1
fi

if ! command -v python3 &>/dev/null; then
  echo "Error: python3 not found in PATH." >&2
  exit 1
fi

if [[ ! -f "$SITES_JSON" ]]; then
  echo "Error: Local sites metadata not found: $SITES_JSON" >&2
  echo "Is Local by Flywheel installed and initialized?" >&2
  exit 1
fi

# -- Helpers ---------------------------------------------------------------

list_sites() {
  SITES_JSON_PATH="$SITES_JSON" STATUSES_JSON_PATH="$STATUSES_JSON" python3 - <<'PY'
import json
import os

sites_path = os.path.expanduser(os.environ["SITES_JSON_PATH"])
statuses_path = os.path.expanduser(os.environ["STATUSES_JSON_PATH"])

with open(sites_path, encoding="utf-8") as f:
    sites = json.load(f)

statuses = {}
if os.path.exists(statuses_path):
    with open(statuses_path, encoding="utf-8") as f:
        statuses = json.load(f)

for s in sorted(sites.values(), key=lambda x: x["name"]):
    status = statuses.get(s["id"], "unknown")
    marker = "*" if status == "running" else "-"
    print(f"  {marker} {s['name']:20s} {status:10s} {s['path']}")
PY
}

# Auto-detect site from CWD: find the site whose path is the longest
# prefix of the current directory.
auto_detect_site() {
  SITES_JSON_PATH="$SITES_JSON" python3 - <<'PY'
import json
import os
import sys

cwd = os.getcwd()
sites_path = os.path.expanduser(os.environ["SITES_JSON_PATH"])

with open(sites_path, encoding="utf-8") as f:
    sites = json.load(f)

best = None
best_len = 0
for s in sites.values():
    p = s["path"].rstrip("/")
    # CWD must equal the site path or be a subdirectory of it
    if cwd == p or cwd.startswith(p + "/"):
        if len(p) > best_len:
            best = s
            best_len = len(p)

if best is None:
    sys.exit(1)

php_ver = best["services"]["php"]["version"]
mysql_ver = best["services"]["mysql"]["version"]
print(f"{best['id']}|{best['name']}|{best['path']}|{php_ver}|{mysql_ver}")
PY
}

lookup_site_by_name() {
  local name="$1"
  SITE_LOOKUP_NAME="$name" SITES_JSON_PATH="$SITES_JSON" python3 - <<'PY' 2>/dev/null
import json
import os
import sys

sites_path = os.path.expanduser(os.environ["SITES_JSON_PATH"])
lookup_name = os.environ["SITE_LOOKUP_NAME"]

with open(sites_path, encoding="utf-8") as f:
    sites = json.load(f)

for s in sites.values():
    if s["name"] == lookup_name:
        php_ver = s["services"]["php"]["version"]
        mysql_ver = s["services"]["mysql"]["version"]
        print(f"{s['id']}|{s['name']}|{s['path']}|{php_ver}|{mysql_ver}")
        sys.exit(0)

sys.exit(1)
PY
}

check_site_status() {
  local site_id="$1"
  local site_name="$2"
  SITE_ID="$site_id" SITE_NAME="$site_name" STATUSES_JSON_PATH="$STATUSES_JSON" python3 - <<'PY'
import json
import os
import sys

statuses_path = os.path.expanduser(os.environ["STATUSES_JSON_PATH"])

if not os.path.exists(statuses_path):
    sys.exit(0)

with open(statuses_path, encoding="utf-8") as f:
    statuses = json.load(f)

site_id = os.environ["SITE_ID"]
site_name = os.environ["SITE_NAME"]
status = statuses.get(site_id, "unknown")
if status != "running":
    print(f"Warning: Site '{site_name}' is {status}. It may need to be started in Local.", file=sys.stderr)
PY
}

# Auto-detect the plugin slug from CWD when inside wp-content/plugins/<slug>.
auto_detect_plugin() {
  local cwd
  cwd="$(pwd)"
  # Match the path segment immediately following wp-content/plugins/
  if [[ "$cwd" == *"/wp-content/plugins/"* ]]; then
    local rest="${cwd#*/wp-content/plugins/}"
    local slug="${rest%%/*}"
    if [[ -n "$slug" ]]; then
      echo "$slug"
      return 0
    fi
  fi
  return 1
}

# -- Parse arguments -------------------------------------------------------

SITE_NAME=""

# Handle --list
if [[ "${1:-}" == "--list" ]]; then
  echo "Local by Flywheel sites:"
  echo ""
  list_sites
  exit 0
fi

# Handle --site=<name>
if [[ "${1:-}" == --site=* ]]; then
  SITE_NAME="${1#--site=}"
  shift
fi

# -- Resolve site ----------------------------------------------------------

SITE_INFO=""

if [[ -n "$SITE_NAME" ]]; then
  SITE_INFO=$(lookup_site_by_name "$SITE_NAME") || {
    echo "Error: Site '$SITE_NAME' not found in Local by Flywheel." >&2
    echo "" >&2
    echo "Available sites:" >&2
    list_sites >&2
    exit 1
  }
else
  SITE_INFO=$(auto_detect_site 2>/dev/null) || true

  if [[ -z "$SITE_INFO" ]]; then
    echo "Error: Could not auto-detect site from current directory." >&2
    echo "Use --site=<name> or cd into a Local site directory." >&2
    echo "" >&2
    echo "Available sites:" >&2
    list_sites >&2
    exit 1
  fi
fi

IFS='|' read -r SITE_ID SITE_NAME SITE_PATH PHP_VER MYSQL_VER <<< "$SITE_INFO"

WP_PATH="$SITE_PATH/app/public"

# -- Resolve plugin slug ---------------------------------------------------

PLUGIN_SLUG=""

# First non-flag argument (not starting with '-') is treated as the slug.
if [[ $# -gt 0 && "${1:0:1}" != "-" ]]; then
  PLUGIN_SLUG="$1"
  shift
else
  PLUGIN_SLUG=$(auto_detect_plugin 2>/dev/null) || true
  if [[ -z "$PLUGIN_SLUG" ]]; then
    echo "Error: No plugin slug provided and none could be auto-detected." >&2
    echo "Pass a slug (pcp <slug>) or cd into wp-content/plugins/<slug>." >&2
    exit 1
  fi
fi

# -- Warn if site is not running ------------------------------------------

check_site_status "$SITE_ID" "$SITE_NAME"

# -- Resolve PHP binary ----------------------------------------------------

PHP_BASE=$(find "$LOCAL_BASE/lightning-services" -maxdepth 1 -type d -name "php-${PHP_VER}*" | LC_ALL=C sort | head -1)
if [[ -z "$PHP_BASE" ]]; then
  echo "Error: Could not find PHP $PHP_VER in Local lightning-services." >&2
  exit 1
fi
PHP_BIN="$PHP_BASE/bin/$ARCH_DIR/bin/php"

# -- Resolve MySQL binary directory ---------------------------------------

MYSQL_BASE=$(find "$LOCAL_BASE/lightning-services" -maxdepth 1 -type d -name "mysql-${MYSQL_VER}*" | LC_ALL=C sort | head -1)
if [[ -z "$MYSQL_BASE" ]]; then
  echo "Error: Could not find MySQL $MYSQL_VER in Local lightning-services." >&2
  exit 1
fi
MYSQL_BIN_DIR="$MYSQL_BASE/bin/$ARCH_DIR/bin"

# -- Site-specific php.ini -------------------------------------------------

PHP_INI="$LOCAL_BASE/run/$SITE_ID/conf/php/php.ini"

if [[ ! -f "$PHP_INI" ]]; then
  echo "Error: php.ini not found at $PHP_INI" >&2
  echo "Is the '$SITE_NAME' site running in Local?" >&2
  exit 1
fi

# -- MySQL client config (socket, credentials) ----------------------------

MYSQL_CONF_DIR="$LOCAL_BASE/run/$SITE_ID/conf/mysql"
if [[ -f "$MYSQL_CONF_DIR/my.cnf" ]]; then
  export MYSQL_HOME="$MYSQL_CONF_DIR"
fi

MYSQL_SOCKET="$LOCAL_BASE/run/$SITE_ID/mysql/mysqld.sock"
if [[ -S "$MYSQL_SOCKET" ]]; then
  export MYSQL_UNIX_PORT="$MYSQL_SOCKET"
fi

export PATH="$MYSQL_BIN_DIR:$PATH"

# -- Verify the Plugin Check plugin is available --------------------------

if ! "$PHP_BIN" -c "$PHP_INI" "$WP_CLI_BIN" --path="$WP_PATH" cli has-command "plugin check" >/dev/null 2>&1; then
  echo "Error: The 'plugin check' command is not available on '$SITE_NAME'." >&2
  echo "Install and activate the Plugin Check plugin first, e.g. via wp-cli-local:" >&2
  echo "  bash <wp-cli-local>/scripts/wp --site=$SITE_NAME plugin install plugin-check --activate" >&2
  exit 1
fi

# -- Execute Plugin Check --------------------------------------------------

echo "[$SITE_NAME] wp plugin check $PLUGIN_SLUG $*" >&2

exec "$PHP_BIN" -c "$PHP_INI" "$WP_CLI_BIN" --path="$WP_PATH" plugin check "$PLUGIN_SLUG" "$@"
