#!/bin/bash
# Generate .envrc files for Local by Flywheel sites
#
# This enables direnv to automatically set up the correct PHP, MySQL,
# and WP-CLI environment when you cd into a Local site directory.
#
# Usage:
#   setup-direnv                  # generate .envrc for ALL sites
#   setup-direnv <site-name>      # generate .envrc for one site
#   setup-direnv --list           # show sites that would be configured
#
# After running, cd into a site directory and run: direnv allow

set -euo pipefail

LOCAL_BASE="$HOME/Library/Application Support/Local"
SITES_JSON="$LOCAL_BASE/sites.json"
ARCH="$(uname -m)"

if [[ "$ARCH" == "arm64" ]]; then
  ARCH_DIR="darwin-arm64"
else
  ARCH_DIR="darwin"
fi

if ! command -v python3 &>/dev/null; then
  echo "Error: python3 not found in PATH." >&2
  exit 1
fi

if [[ ! -f "$SITES_JSON" ]]; then
  echo "Error: Local sites metadata not found: $SITES_JSON" >&2
  echo "Is Local by Flywheel installed and initialized?" >&2
  exit 1
fi

# -- Helpers ---------------------------------------------------------------

get_sites_json() {
  local filter="${1:-}"
  FILTER_NAME="$filter" SITES_JSON_PATH="$SITES_JSON" python3 - <<'PY'
import json
import os
import sys

sites_path = os.path.expanduser(os.environ["SITES_JSON_PATH"])
filter_name = os.environ.get("FILTER_NAME", "")

with open(sites_path, encoding="utf-8") as f:
    sites = json.load(f)

matched = False
for s in sorted(sites.values(), key=lambda x: x["name"]):
    if filter_name and s["name"] != filter_name:
        continue
    matched = True
    php_ver = s["services"]["php"]["version"]
    mysql_ver = s["services"]["mysql"]["version"]
    print(f"{s['id']}|{s['name']}|{s['path']}|{php_ver}|{mysql_ver}")

if filter_name and not matched:
    print(f"Error: Site '{filter_name}' not found.", file=sys.stderr)
    sys.exit(1)
PY
}

resolve_php_bin() {
  local php_ver="$1"
  local php_base
  php_base=$(find "$LOCAL_BASE/lightning-services" -maxdepth 1 -type d -name "php-${php_ver}*" | LC_ALL=C sort | head -1)
  if [[ -z "$php_base" ]]; then
    echo ""
    return
  fi
  echo "$php_base/bin/$ARCH_DIR/bin/php"
}

resolve_mysql_bin_dir() {
  local mysql_ver="$1"
  local mysql_base
  mysql_base=$(find "$LOCAL_BASE/lightning-services" -maxdepth 1 -type d -name "mysql-${mysql_ver}*" | LC_ALL=C sort | head -1)
  if [[ -z "$mysql_base" ]]; then
    echo ""
    return
  fi
  echo "$mysql_base/bin/$ARCH_DIR/bin"
}

generate_envrc() {
  local site_id="$1"
  local site_name="$2"
  local site_path="$3"
  local php_ver="$4"
  local mysql_ver="$5"

  local php_bin
  php_bin=$(resolve_php_bin "$php_ver")
  if [[ -z "$php_bin" ]]; then
    echo "  ! Skipping $site_name: PHP $php_ver not found in lightning-services"
    return 1
  fi

  local mysql_bin_dir
  mysql_bin_dir=$(resolve_mysql_bin_dir "$mysql_ver")
  if [[ -z "$mysql_bin_dir" ]]; then
    echo "  ! Skipping $site_name: MySQL $mysql_ver not found in lightning-services"
    return 1
  fi

  local php_ini="$LOCAL_BASE/run/$site_id/conf/php/php.ini"
  local wp_path="$site_path/app/public"

  local envrc_path="$site_path/.envrc"

  cat > "$envrc_path" <<ENVRC
# Auto-generated by wp-cli-local/scripts/setup-direnv
# Site: $site_name | PHP $php_ver | MySQL $mysql_ver
#
# This configures WP-CLI to use LocalWP's PHP and MySQL binaries.
# The site must be running in Local for the php.ini to exist.

# PHP binary from Local's lightning-services
export WP_CLI_PHP="$php_bin"

# Site-specific php.ini (contains MySQL socket path)
_PHP_INI="$php_ini"
if [[ -f "\$_PHP_INI" ]]; then
  export WP_CLI_PHP_ARGS="-c \$_PHP_INI"
else
  echo "! php.ini not found - is '$site_name' running in Local?"
  echo "  Expected: \$_PHP_INI"
fi
unset _PHP_INI

# MySQL binaries from Local's lightning-services
PATH_add "$mysql_bin_dir"

# MySQL socket for wp db commands (mysql CLI needs this)
_MYSQL_SOCK="$LOCAL_BASE/run/$site_id/mysql/mysqld.sock"
if [[ -S "\$_MYSQL_SOCK" ]]; then
  export MYSQL_UNIX_PORT="\$_MYSQL_SOCK"
fi
unset _MYSQL_SOCK

# Convenience: WordPress root for --path
export WP_PATH="$wp_path"
ENVRC

  echo "  + $site_name -> $envrc_path"
}

# -- Main ------------------------------------------------------------------

if [[ "${1:-}" == "--list" ]]; then
  echo "Sites that would receive .envrc files:"
  echo ""
  while IFS='|' read -r id name path php_ver mysql_ver; do
    echo "  $name -> $path/.envrc"
  done < <(get_sites_json)
  exit 0
fi

# Check direnv is installed
if ! command -v direnv &>/dev/null; then
  echo "Note: direnv is not installed. Install it with:"
  echo "  brew install direnv"
  echo ""
  echo "Then add to your shell rc file:"
  echo "  eval \"\$(direnv hook zsh)\"   # for zsh"
  echo "  eval \"\$(direnv hook bash)\"  # for bash"
  echo ""
  echo "Generating .envrc files anyway..."
  echo ""
fi

FILTER="${1:-}"
GENERATED=0
SKIPPED=0

echo "Generating .envrc files for Local sites..."
echo ""

while IFS='|' read -r id name path php_ver mysql_ver; do
  if generate_envrc "$id" "$name" "$path" "$php_ver" "$mysql_ver"; then
    GENERATED=$((GENERATED + 1))
  else
    SKIPPED=$((SKIPPED + 1))
  fi
done < <(get_sites_json "$FILTER")

echo ""
echo "Summary: generated=$GENERATED skipped=$SKIPPED"
echo "Done. To activate, cd into a site directory and run:"
echo "  direnv allow"
echo ""
echo "Then you can use bare wp commands:"
echo "  wp --path=./app/public plugin list"
